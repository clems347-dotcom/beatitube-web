{
  "rewrites": [
    { "source": "/track/:id", "destination": "/api/track/:id" },
    { "source": "/cgu", "destination": "/cgu.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html" },
    { "source": "/auth/reset-password", "destination": "/auth/reset-password.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/space_static.(webp|png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/logo.(svg|png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
